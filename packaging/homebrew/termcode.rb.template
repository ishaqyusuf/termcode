class Termcode < Formula
  desc "Jump into and run scripts for local JavaScript projects"
  homepage "https://github.com/your-name/termcode"
  url "https://github.com/your-name/termcode/archive/refs/tags/v0.1.0.tar.gz"
  sha256 "CHANGE_ME_AFTER_TAGGING_RELEASE"
  license "MIT"

  def install
    bin.install "bin/termcode"
  end

  test do
    assert_match "termcode 0.1.0", shell_output("#{bin}/termcode --version")
  end
end
